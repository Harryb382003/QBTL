package proc::LiveMetadataInfill;

use v5.40;
use common::sense;
use feature qw( signatures );

use Exporter qw( import );

our @EXPORT_OK = qw(
  is_private_value
  torrent_is_private
  torrent_needs_tracker_list
  live_metadata_infill_plan
  run_live_metadata_infill
);

=head1 NAME

proc::LiveMetadataInfill - generic live qBT metadata infill planning

=head1 DESCRIPTION

This module decides which extra live qBittorrent API calls are worth making
for a torrent.  It intentionally does not know about ExportDedupe, qBT client
classes, DB handles, or renderers.

Policy:

=over 4

=item * comment is live-only enough to always be worth infilling

=item * file_list is live-only enough to always be worth infilling

=item * tracker list is needed for public torrents

=item * private torrents can rely on the single tracker/announce already
available from the normal C<torrents_info> slurp

=item * unknown C<is_private> is treated conservatively as needing tracker list

=back

=cut

sub is_private_value ( $value ) {
  return undef if !defined $value;

  return $value ? 1 : 0 if !ref($value) && $value =~ /\A[01]\z/;

  if ( !ref($value) ) {
    my $v = lc $value;
    return 1 if $v =~ /\A(?:true|yes|private)\z/;
    return 0 if $v =~ /\A(?:false|no|public)\z/;
  }

  return $value ? 1 : 0;
}

sub torrent_is_private ( $torrent ) {
  die "torrent_is_private requires a hashref torrent\n"
      unless ref($torrent) eq 'HASH';

  return is_private_value( $torrent->{is_private} );
}

sub torrent_needs_tracker_list ( $torrent ) {
  my $is_private = torrent_is_private($torrent);

  # Unknown private/public state should not cause silent tracker loss.
  return 1 if !defined $is_private;

  # Private: one announce/tracker from torrents_info is enough for this phase.
  # Public: fetch the full tracker list.
  return $is_private ? 0 : 1;
}

sub live_metadata_infill_plan ( @torrents ) {
  my @plan;

  for my $torrent (@torrents) {
    die "live_metadata_infill_plan requires hashref torrents\n"
        unless ref($torrent) eq 'HASH';

    my $hash = $torrent->{hash}
        // $torrent->{infohash}
        // $torrent->{info_hash};

    die "torrent is missing hash/infohash\n"
        unless defined $hash && length $hash;

    push @plan,
        {
          hash            => $hash,
          name            => $torrent->{name},
          is_private      => torrent_is_private($torrent),
          fetch_comment   => 1,
          fetch_file_list => 1,
          fetch_trackers  => torrent_needs_tracker_list($torrent),
        };
  }

  return @plan;
}

sub run_live_metadata_infill ( %args ) {
  my $torrents = $args{torrents};
  die "run_live_metadata_infill requires torrents => ARRAY\n"
      unless ref($torrents) eq 'ARRAY';

  for my $name (qw(
    fetch_comment
    fetch_file_list
    store_comment
    store_file_list
  )) {
    die "run_live_metadata_infill requires $name => CODE\n"
        unless ref( $args{$name} ) eq 'CODE';
  }

  die "run_live_metadata_infill requires fetch_trackers => CODE when storing trackers\n"
      if $args{store_trackers}
      && ref( $args{fetch_trackers} ) ne 'CODE';

  my @plan = live_metadata_infill_plan(@$torrents);

  my $summary = {
    torrents        => scalar @plan,
    comments        => 0,
    file_lists      => 0,
    tracker_lists   => 0,
    skipped_private => 0,
    errors          => [],
  };

  for my $item (@plan) {
    my $hash = $item->{hash};

    eval {
      my $comment = $args{fetch_comment}->($hash);
      $args{store_comment}->( $hash, $comment );
      $summary->{comments}++;

      my $files = $args{fetch_file_list}->($hash);
      $args{store_file_list}->( $hash, $files );
      $summary->{file_lists}++;

      if ( $item->{fetch_trackers} ) {
        my $trackers = $args{fetch_trackers}->($hash);
        $args{store_trackers}->( $hash, $trackers )
            if ref( $args{store_trackers} ) eq 'CODE';
        $summary->{tracker_lists}++;
      } else {
        $summary->{skipped_private}++;
      }

      1;
    } or do {
      my $err = $@ || 'unknown live metadata infill error';
      chomp $err;
      push @{ $summary->{errors} },
          {
            hash  => $hash,
            name  => $item->{name},
            error => $err,
          };
    };
  }

  return $summary;
