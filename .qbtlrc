[ QBTL user configuration ]

[time_format]
# Choose how qBT epoch timestamps are displayed.
#
# time =   full
# = 2025-02-17 20:03:38
#
time = ymd
# = 2025-02-17
#
# time =   time
# = 20:03:38

[installation]
root = $home/QBTL
config = $home/QBTL/.qbtlrc

[qbt]
url = http://localhost:8080

[database]
path = $HOME/QBTL/qbtl.db

[metadata]
promoter_threshold = 1

[local]
search_tool = mdfind
