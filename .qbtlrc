[ QBTL user configuration ]

[time_format]
# Choose how qBT epoch timestamps are displayed.
#
# time =   full
# = 2025-02-17 20:03:38
#
time = ymd
# = 2025-02-17
#
# time =   time
# = 20:03:38

[qbt]
url = http://localhost:8080

[database]
path = $ENV{HOME}/QBTL/qbtl.db

[metadata]
promoter_threshold = 1
