#!/usr/bin/env perl

use v5.40;
use common::sense;
use feature qw( signatures );

use lib 'lib';
use QBTL;

my $cmd = shift @ARGV // 'help';

if ( $cmd eq 'version' ) {
  say "QBTL $QBTL::VERSION";
  exit 0;
}

say "Usage: qbtl <command>";
say "";
say "Commands:";
say "  version    Show QBTL version";

exit 0;
